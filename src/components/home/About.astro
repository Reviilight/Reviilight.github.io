---
import BskyIcon from "@/assets/icons/bluesky.svg";
const nickname = "Reviilight";
---

<section class="about-section">
    <div class="about-section__element about-section__profile">
        <img
            class="profile-picture"
            src="https://avatars.githubusercontent.com/u/55348885"
            alt="A profile picture"
        />
        <h1>{nickname}</h1>
    </div>
    <div class="about-section__element about-section__about">
        <h2>About</h2>
        <p>I'm a developer.</p>
    </div>
    <div class="about-section__element about-section__contacts">
        <h2>Contacts</h2>
        <div class="contacts-grid">
            <a
                class="contact"
                href="https://bsky.app/profile/reviilight.bsky.social"
            >
                <BskyIcon class="contact__icon" />
                <span class="contact__text">BlueSky</span>
            </a>
        </div>
    </div>
</section>

<style>
    .about-section {
        background-color: aquamarine;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .about-section__element {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .about-section__profile {
    }

    .about-section__about {
    }

    .about-section__contacts {
    }

    .contacts-grid {
        margin-bottom: 15px;
    }

    .contact {
        text-decoration: none;
        color: inherit;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 10px;
        border-radius: 25%;
        box-shadow: 0px 10px 20px 0px rgba(0, 0, 0, 0.2);
        transition:
            box-shadow 0.5s cubic-bezier(0.445, 0.05, 0.55, 0.95),
            transform 0.3s cubic-bezier(0.68, -0.55, 0.265, 1.55);
        background: linear-gradient(
            163deg,
            rgb(255, 255, 255) 0%,
            rgb(255, 255, 255) 50%,
            rgb(206, 245, 255) 100%
        );
    }

    .contact:hover {
        /*box-shadow: 0px 15px 25px 0px rgba(0, 0, 0, 0.2);*/
        transform: scale(1.1);
    }

    .contact:hover .contact__icon {
        transform: scale(0.9);
        margin-top: 2px;
    }

    .contact:hover .contact__text {
        transform: scale(0.9);
        margin-top: -4px;
    }

    .contact__text {
        transition: all 0.3s cubic-bezier(0.68, -0.55, 0.265, 1.55);
    }

    .contact__icon {
        width: 32px;
        height: 32px;
        display: block;
        margin: 0px 10px 10px 10px;
        transition: all 0.3s cubic-bezier(0.68, -0.55, 0.265, 1.55);
    }

    .profile-picture {
        border-radius: 100%;
        height: 128px;
        box-shadow: 0px 10px 34px -14px rgba(0, 0, 0, 0.36);
    }

    @media (min-width: 768px) {
        .about-section {
            flex-direction: row;
            align-items: normal;
        }

        .about-section__about {
            order: -1;
        }
    }
</style>
