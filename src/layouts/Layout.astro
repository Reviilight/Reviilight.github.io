---
import { getImage } from "astro:assets";
import "@/styles/global.css";
import BackgroundBack from "@/assets/backgrounds/nefiya_intro_wp_back.png";
import BackgroundLeft from "@/assets/backgrounds/nefiya_intro_wp_left.png";
import BackgroundRight from "@/assets/backgrounds/nefiya_intro_wp_right.png";

const optimizedBackgroundBack = await getImage({ src: BackgroundBack });
const optimizedBackgroundLeft = await getImage({ src: BackgroundLeft });
const optimizedBackgroundRight = await getImage({ src: BackgroundRight });
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<!-- <link rel="icon" type="image/svg+xml" href="/favicon.svg" /> -->
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Reviilight</title>
		<meta name="description" content="Reviilight's personal website" />
	</head>
	<body
		style={`background-image: 
			url('${optimizedBackgroundRight.src}'),
			url('${optimizedBackgroundLeft.src}'),
			url('${optimizedBackgroundBack.src}');`}
	>
		<slot />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
		font-family: sans-serif;
	}

	body {
		background-size: contain, cover, cover;
		background-position:
			right calc(-670px + 30vw) center,
			left -440px center,
			center center;
		background-attachment: fixed;
		background-repeat: no-repeat;
	}
</style>
